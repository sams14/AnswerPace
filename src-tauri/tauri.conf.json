{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnswerPace",
  "version": "0.1.0",
  "identifier": "in.answerpace.desktop",
  "build": {
    "frontendDist": "../app",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run serve:app",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "AnswerPace",
        "width": 1000,
        "height": 720,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
